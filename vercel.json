{
  "buildCommand": "cd apps/web && bun install && bun run build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/apps/api/main.py" }
  ],
  "functions": {
    "apps/api/main.py": {
      "runtime": "python3.12",
      "maxDuration": 30
    }
  }
}
